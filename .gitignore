# Root .gitignore for the full Trello workspace

# Node frontend
task-canvas/node_modules/
task-canvas/dist/
task-canvas/dist-ssr/
task-canvas/.vite/
task-canvas/.pnpm/
task-canvas/npm-debug.log*
task-canvas/yarn-debug.log*
task-canvas/yarn-error.log*
task-canvas/pnpm-debug.log*

# Python backend
backend/__pycache__/
backend/*.py[cod]
backend/*.pyo
backend/.Python
backend/venv/
backend/.venv/
backend/env/
backend/.env
backend/.env.*

# General files
.vscode/
.idea/
.DS_Store
Thumbs.db
desktop.ini
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.env
.env.*
*.tmp
*.temp
*.cache
coverage/
build/
